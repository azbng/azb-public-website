# Public website runtime configuration
# Copy to `.env` for local dev or set as environment variables in Vercel/shared hosting.

# Backend API base (ERP backend)
VITE_API_BASE_URL=https://api.azbltd.com

# Public app origin (used for callback URLs if needed)
VITE_PUBLIC_APP_ORIGIN=https://www.azbltd.com

# Solar public API prefix on backend
VITE_SOLAR_PUBLIC_API_PREFIX=/api/public/solar

# Feature flag: set true while still using localStorage mock data.
# Must be false in production when backend integration is enabled.
VITE_USE_SOLAR_MOCK=false

# Google OAuth client id for public portal users
VITE_GOOGLE_CLIENT_ID=

# Optional CAPTCHA site key for signup/loan/booking submissions
VITE_RECAPTCHA_SITE_KEY=

# Request timeout in milliseconds
VITE_API_TIMEOUT_MS=15000
